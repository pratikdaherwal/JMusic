<?xml version="1.0" encoding="utf-8"?>
<!-- Full Screen Player Layout - Opens when swiping up from mini player -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fullScreenPlayerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fullscreen_player_background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_keyboard_arrow_down"
            app:titleTextColor="@android:color/white"
            app:title="@string/now_playing" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Album Art - Large centered image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_gravity="center">

            <ImageView
                android:id="@+id/fullAlbumArt"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music_note"
                android:contentDescription="@string/album_art"
                android:background="@drawable/album_art_full_background"
                android:maxWidth="400dp"
                android:maxHeight="400dp"
                android:layout_gravity="center" />

        </FrameLayout>

        <!-- Song Info Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/fullSongTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/song_title"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center" />

            <TextView
                android:id="@+id/fullArtistName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/artist_name"
                android:textColor="#B3FFFFFF"
                android:textSize="16sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="center"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Progress Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/currentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/fullProgressBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:max="100"
                android:progress="30"
                style="@style/Widget.AppCompat.SeekBar"
                android:progressDrawable="@drawable/seekbar_progress"
                android:thumb="@drawable/seekbar_thumb" />

            <TextView
                android:id="@+id/totalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3:45"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Playback Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <!-- Shuffle Button -->
            <ImageButton
                android:id="@+id/shuffleBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_shuffle"
                android:contentDescription="@string/shuffle"
                app:tint="#B3FFFFFF" />

            <!-- Previous Button -->
            <ImageButton
                android:id="@+id/previousBtn"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_previous"
                android:contentDescription="@string/previous"
                app:tint="@android:color/white" />

            <!-- Play/Pause Button (Large) -->
            <ImageButton
                android:id="@+id/fullPlayPauseBtn"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/play_pause_button_background"
                android:src="@drawable/ic_play_arrow"
                android:contentDescription="@string/play_pause"
                app:tint="@android:color/white"
                android:scaleType="centerInside"
                android:padding="16dp" />

            <!-- Next Button -->
            <ImageButton
                android:id="@+id/nextBtn"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_next"
                android:contentDescription="@string/next"
                app:tint="@android:color/white" />

            <!-- Repeat Button -->
            <ImageButton
                android:id="@+id/repeatBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_repeat"
                android:contentDescription="@string/repeat"
                app:tint="#B3FFFFFF" />

        </LinearLayout>

        <!-- Additional Options (Optional) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/lyricsBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_lyrics"
                android:contentDescription="@string/lyrics"
                app:tint="#B3FFFFFF"
                android:layout_marginEnd="32dp" />

            <ImageButton
                android:id="@+id/queueBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_queue_music"
                android:contentDescription="@string/queue"
                app:tint="#B3FFFFFF"
                android:layout_marginEnd="32dp" />

            <ImageButton
                android:id="@+id/shareBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_share"
                android:contentDescription="@string/share"
                app:tint="#B3FFFFFF" />

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
